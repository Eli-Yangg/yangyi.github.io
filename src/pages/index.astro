---
import BaseLayout from "../layouts/BaseLayout.astro";
import ParticlesBackground from "../components/particles/ParticlesBackground";
import BlogStatsSection from "../components/BlogStatsSection.astro";
import { getCollection } from "astro:content";

// 获取所有博客文章
const allPosts = await getCollection("blog");
---

<BaseLayout>
  <main class="relative min-h-screen overflow-hidden">
    <!-- 粒子背景 -->
    <ParticlesBackground client:load />
    
    <!-- 渐变背景 -->
    <div class="absolute inset-0 -z-10">
      <div
        class="absolute left-1/2 top-40 h-[500px] w-[500px] -translate-x-1/2 rounded-full bg-violet-600/30 blur-3xl glow"
      >
      </div>
    </div>

    <!-- Header -->
    <header
      class="relative z-10 mx-auto flex max-w-7xl items-center justify-between px-6 py-6"
    >
      <h1 class="text-xl font-semibold tracking-wide">Eli.dev</h1>
      <nav class="flex items-center gap-8 text-sm text-slate-300">
        <a href="#blog-stats" class="transition hover:text-violet-400">Blog</a>
        <a href="#" class="transition hover:text-violet-400">Projects</a>
        <a href="#" class="transition hover:text-violet-400">About</a>
      </nav>
    </header>

    <!-- Hero Section -->
    <section
      class="relative z-10 mx-auto flex min-h-[80vh] max-w-7xl flex-col items-center justify-center px-6 text-center"
    >
      <div class="glass rounded-full px-4 py-2 text-sm text-slate-300">
        Frontend Engineer · React · Astro
      </div>
      <h2 class="mt-8 max-w-4xl text-5xl font-bold leading-tight md:text-7xl">
        Build Beautiful
        <span
          class="bg-gradient-to-r from-violet-400 to-fuchsia-300 bg-clip-text text-transparent"
        >
          Developer Experience
        </span>
      </h2>
      <p class="mt-8 max-w-2xl text-lg leading-8 text-slate-400">
        分享前端开发、React、性能优化、AI 与现代 Web 技术。
      </p>
      <div class="mt-10 flex gap-4">
        <a
          href="/blog"
          class="rounded-xl bg-violet-600 px-6 py-3 font-medium transition hover:bg-violet-500"
        >
          阅读博客
        </a>
        <a
          href="https://github.com/Eli-Yangg"
          target="_blank"
          rel="noopener noreferrer"
          class="glass rounded-xl px-6 py-3 font-medium transition hover:border-violet-500"
        >
          GitHub
        </a>
      </div>
    </section>

    <!-- 博客统计部分 -->
    <section id="blog-stats" class="relative z-0" data-stats-section>
      <BlogStatsSection />
    </section>
  </main>
</BaseLayout>

<style is:global>
  .glass {
    background: rgba(15, 23, 42, 0.5);
    border: 1px solid rgba(167, 139, 250, 0.2);
  }

  .glow {
    animation: glow 4s ease-in-out infinite;
  }

  @keyframes glow {
    0%,
    100% {
      filter: blur(3rem) opacity(0.3);
    }
    50% {
      filter: blur(3rem) opacity(0.5);
    }
  }
</style>
