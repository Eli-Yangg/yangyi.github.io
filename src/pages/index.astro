---
import BaseLayout from "../layouts/BaseLayout.astro";
import ParticlesBackground from "../components/particles/ParticlesBackground";
import BlogStatsSection from "../components/BlogStatsSection.astro";
import TimelineWatermark from "../components/hero/TimelineWatermark";
---

<BaseLayout>
  <main class="relative min-h-screen overflow-hidden">
    <!-- 粒子背景 -->
    <ParticlesBackground client:load />

    <!-- 渐变背景 -->
    <div class="absolute inset-0 -z-10">
      <div
        class="glow absolute top-40 left-1/2 h-125 w-125 -translate-x-1/2 rounded-full bg-violet-600/30 blur-3xl"
      >
      </div>
    </div>

    <!-- 第一屏：Header + Hero，严格占满视口高度 -->
    <div class="relative flex h-screen flex-col">
      <!-- 左上角时间线水印 -->
      <TimelineWatermark client:load />

      <!-- Header -->
      <header
        class="relative z-10 mx-auto flex w-full max-w-7xl items-center justify-between px-6 py-6"
      >
        <h1 class="text-xl font-semibold tracking-wide">Eli.dev</h1>
        <nav class="flex items-center gap-8 text-sm text-slate-300">
          <a href="#blog-stats" class="transition hover:text-violet-400">Blog</a>
          <a href="#" class="transition hover:text-violet-400">Projects</a>
          <a href="#" class="transition hover:text-violet-400">About</a>
        </nav>
      </header>

      <!-- Hero Section -->
      <section
        class="relative z-10 mx-auto flex w-full max-w-7xl flex-1 flex-col items-center justify-center px-6 text-center"
      >
        <div class="glass-fade-in rounded-full px-4 py-2 text-sm text-slate-300">
          Frontend Engineer · React · Astro
        </div>
        <h2 class="hero-title mt-8 max-w-4xl text-5xl leading-tight font-bold md:text-7xl">
          <span class="reveal-mask" style="animation-delay: 0.2s">
            <span style="animation-delay: 0.2s">Build Beautiful</span>
          </span>
          <br />
          <span class="reveal-mask" style="animation-delay: 0.45s">
            <span
              class="inline-block bg-gradient-to-r from-violet-400 to-fuchsia-300 bg-clip-text text-transparent"
              style="animation-delay: 0.45s;"
            >
              Developer Experience
            </span>
          </span>
        </h2>
        <p class="hero-desc mt-8 max-w-2xl text-lg leading-8 text-slate-400">
          分享前端开发、React、性能优化、AI 与现代 Web 技术。
        </p>
        <div class="hero-buttons mt-10 flex gap-4">
          <a
            href="/blog"
            class="group relative overflow-hidden rounded-xl bg-linear-to-r from-violet-600 to-fuchsia-600 px-6 py-3 font-medium shadow-lg shadow-violet-500/30 transition hover:shadow-xl hover:shadow-violet-500/50"
          >
            <span class="relative z-10">阅读博客</span>
            <span
              class="absolute inset-0 -translate-x-full bg-linear-to-r from-transparent via-white/20 to-transparent transition-transform duration-700 group-hover:translate-x-full"
            ></span>
          </a>
          <a
            href="https://github.com/Eli-Yangg"
            target="_blank"
            rel="noopener noreferrer"
            class="glass rounded-xl px-6 py-3 font-medium transition hover:border-violet-500 hover:shadow-lg hover:shadow-violet-500/30"
          >
            GitHub
          </a>
        </div>
      </section>
    </div>

    <!-- 博客统计部分 -->
    <section id="blog-stats" class="relative z-0" data-stats-section>
      <BlogStatsSection />
    </section>
  </main>
</BaseLayout>

<style is:global>
  .glass {
    background: rgba(15, 23, 42, 0.5);
    border: 1px solid rgba(167, 139, 250, 0.2);
  }

  .glow {
    animation: glow 4s ease-in-out infinite;
  }

  @keyframes glow {
    0%,
    100% {
      filter: blur(3rem) opacity(0.3);
    }
    50% {
      filter: blur(3rem) opacity(0.5);
    }
  }

  /* Hero Section 动画 */
  .glass-fade-in {
    animation: fadeInScale 0.8s ease-out forwards;
    opacity: 0;
  }

  .hero-title {
    animation: fadeInOnly 0.1s linear 0.1s forwards;
    opacity: 0;
  }

  .hero-desc {
    animation: fadeInSlideUp 1s ease-out 0.9s forwards;
    opacity: 0;
  }

  .hero-buttons {
    animation: fadeInSlideUp 1s ease-out 1.1s forwards;
    opacity: 0;
  }

  @keyframes fadeInOnly {
    to {
      opacity: 1;
    }
  }

  @keyframes fadeInScale {
    from {
      opacity: 0;
      transform: scale(0.95);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  @keyframes fadeInSlideUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
