---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <main class="relative min-h-screen overflow-hidden">
    <div class="absolute inset-0 -z-10">
      <div
        class="absolute left-1/2 top-40 h-[500px] w-[500px] -translate-x-1/2 rounded-full bgviolet-600/30 blur-3xl glow"
      >
      </div>
    </div>
    <header
      class="mx-auto flex max-w-7xl items-center justify-between px-6 py-6"
    >
      <h1 class="text-xl font-semibold tracking-wide">Eli.dev</h1>
      <nav class="flex items-center gap-8 text-sm text-slate-300">
        <a href="#">Blog</a>
        <a href="#">Projects</a>
        <a href="#">About</a>
      </nav>
    </header>
    <section
      class="mx-auto flex min-h-[80vh] max-w-7xl flex-col items-center justify-center px-6
text-center"
    >
      <div class="glass rounded-full px-4 py-2 text-sm text-slate-300">
        Frontend Engineer · React · Astro
      </div>
      <h2 class="mt-8 max-w-4xl text-5xl font-bold leading-tight md:text-7xl">
        Build Beautiful
        <span
          class="bg-gradient-to-r from-violet-400 to-fuchsia-300 bg-clip-text texttransparent"
        >
          Developer Experience
        </span>
      </h2>
      <p class="mt-8 max-w-2xl text-lg leading-8 text-slate-400">
        分享前端开发、React、性能优化、AI 与现代 Web 技术。
      </p>
      <div class="mt-10 flex gap-4">
        <a
          href="#"
          class="rounded-xl bg-violet-600 px-6 py-3 font-medium transition hover:bgviolet-500"
        >
          阅读博客
        </a>
        <a
          href="#"
          class="glass rounded-xl px-6 py-3 font-medium transition hover:border-violet-500"
        >
          GitHub
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
